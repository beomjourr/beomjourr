---
import profile from '../data/profile';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-accent/5 via-transparent to-transparent"></div>
  <!-- Blurred accent circle -->
  <div class="absolute top-1/3 right-0 w-96 h-96 bg-accent/10 rounded-full blur-3xl translate-x-1/3"></div>

  <div class="relative max-w-5xl mx-auto px-6 text-center">
    <p class="slide-up text-dark-muted text-lg mb-4" style="animation-delay: 0s;">
      안녕하세요, 저는
    </p>

    <h1 class="slide-up text-5xl md:text-7xl font-bold text-white mb-4" style="animation-delay: 0.15s;">
      {profile.name}<span class="inline-block w-3 h-3 bg-accent rounded-full ml-1 align-top"></span>
    </h1>

    <p class="slide-up text-2xl md:text-3xl text-accent font-semibold mb-6" style="animation-delay: 0.3s;">
      {profile.role}
    </p>

    <p class="slide-up text-dark-muted text-lg max-w-xl mx-auto mb-10" style="animation-delay: 0.45s;">
      {profile.bio}
    </p>

    <div class="slide-up flex items-center justify-center gap-4" style="animation-delay: 0.6s;">
      <a
        href="#projects"
        class="inline-block px-8 py-3 bg-accent hover:bg-accent-hover text-white font-medium rounded-xl transition-colors duration-300"
      >
        프로젝트 보기
      </a>
      <a
        href="#contact"
        class="inline-block px-8 py-3 border border-dark-border hover:border-accent/50 text-gray-200 font-medium rounded-xl transition-colors duration-300"
      >
        연락하기
      </a>
    </div>
  </div>
</section>
