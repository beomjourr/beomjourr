---
import profile from '../data/profile';
---

<section id="experience" class="section-container">
  <p class="text-accent font-mono text-sm mb-2 slide-up">02.</p>
  <h2 class="section-title slide-up" style="animation-delay: 0.1s;">Experience</h2>
  <p class="section-subtitle slide-up" style="animation-delay: 0.2s;">경력사항</p>

  <div class="relative ml-4">
    <!-- Vertical timeline line -->
    <div class="absolute left-0 top-0 bottom-0 w-px bg-dark-border"></div>

    {profile.experiences.map((exp, index) => (
      <div class="relative pl-10 pb-12 last:pb-0 slide-up" style={`animation-delay: ${0.3 + index * 0.15}s;`}>
        <!-- Timeline dot -->
        <div class="absolute left-0 top-1 w-3 h-3 rounded-full bg-accent shadow-lg shadow-accent/30 -translate-x-1/2"></div>

        <div class="glass-card">
          <h3 class="text-white font-semibold text-lg">{exp.role}</h3>
          <p class="text-accent text-sm font-mono mb-1">{exp.period}</p>
          <p class="text-dark-muted text-sm mb-3">{exp.company}</p>
          <p class="text-dark-muted leading-relaxed mb-4">{exp.description}</p>
          <div class="flex flex-wrap gap-2">
            {exp.techStack.map((tech) => (
              <span class="text-xs font-mono px-3 py-1 rounded-full bg-accent/10 text-accent border border-accent/20">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
